PORT=5000
NODE_ENV=production

# Local Docker Compose can use mongodb://mongo:27017/sas-academy.
# Production should usually use MongoDB Atlas or another managed Mongo URI.
MONGO_URI=mongodb://mongo:27017/sas-academy

JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated frontend origins allowed by CORS.
CLIENT_URLS=http://localhost:8080,https://sasacademy.in

# Gmail app password or SMTP-compatible Gmail credentials used by current mailer.
EMAIL_USER=
EMAIL_PASS=

# Required for audio/file uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
